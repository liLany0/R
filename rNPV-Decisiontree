  geom_vline(xintercept = ci_lower,
             color = "black",    linetype = "dotted", linewidth = 0.9) +
  geom_vline(xintercept = ci_upper,
             color = "black",    linetype = "dotted", linewidth = 0.9) +
  annotate("text", x = mean_enpv, y = Inf,
           label = paste0("Mean: €", formatC(mean_enpv, format = "d", big.mark = ",")),
           vjust = 2, hjust = -0.1, color = "darkred", size = 3.5) +
  theme_minimal(base_size = 11) +
  labs(
    title    = "Probabilistic Sensitivity Analysis (Monte Carlo — PERT)",
    subtitle = paste0(
      formatC(n_sims, format = "d", big.mark = ","),
      " simulations  |  95% CI: €",
      formatC(ci_lower, format = "d", big.mark = ","),
      " to €",
