  )


set.seed(42)   # reproducibility
n_sims     <- 10000
psa_params <- assumptions_data %>% filter(Min != Max)

# Pre-generate all PERT samples at once (faster than sampling inside loop)
simulated_inputs <- data.frame(Simulation_ID = seq_len(n_sims))

for (i in seq_len(nrow(psa_params))) {
  param_name <- psa_params$Parameters[i]
  simulated_inputs[[param_name]] <- rpert(
    n_sims,
    min  = psa_params$Min[i],
    mode = psa_params$Baseline[i],
    max  = psa_params$Max[i]
  )
}

cat("\n--- STEP 1 COMPLETE: 10,000 Scenarios Generated (PERT) ---\n")

psa_enpv_results     <- numeric(n_sims)
psa_breakeven_results <- rep(NA_real_, n_sims)

cat("Starting Monte Carlo engine...\n")

for (sim in seq_len(n_sims)) {
  if (sim %% 1000 == 0) cat(paste("  Simulation", sim, "of", n_sims, "...\n"))
  
  current_assumptions <- assumptions_data
  
  for (i in seq_len(nrow(psa_params))) {
    param_name <- psa_params$Parameters[i]
    current_assumptions$Baseline[current_assumptions$Parameters == param_name] <-
      simulated_inputs[[param_name]][sim]
  }
  
  result <- run_mellozzan_model(current_assumptions)
  
  psa_enpv_results[sim]      <- result$eNPV
  psa_breakeven_results[sim] <- ifelse(is.na(result$BreakEven), NA_real_,
                                       result$BreakEven)
}

cat("--- Monte Carlo Complete ---\n")


mean_enpv    <- mean(psa_enpv_results)
median_enpv  <- median(psa_enpv_results)
ci_lower     <- quantile(psa_enpv_results, 0.025)
ci_upper     <- quantile(psa_enpv_results, 0.975)
prob_of_loss <- mean(psa_enpv_results < 0) * 100

be_counts <- table(factor(psa_breakeven_results,
                          levels = c(sort(unique(na.omit(psa_breakeven_results))), NA)),
                   useNA = "always")
be_probs  <- round((be_counts / n_sims) * 100, 1)

cat("\n==================================================\n")
cat("     MONTE CARLO SIMULATION: EXECUTIVE SUMMARY    \n")
cat("==================================================\n")
cat(paste("Mean Expected NPV:      €", formatC(mean_enpv,   format = "f", digits = 0, big.mark = ","), "\n"))
cat(paste("Median Expected NPV:    €", formatC(median_enpv, format = "f", digits = 0, big.mark = ","), "\n"))
cat(paste("Worst Case (2.5%):      €", formatC(ci_lower,    format = "f", digits = 0, big.mark = ","), "\n"))
cat(paste("Best Case  (97.5%):     €", formatC(ci_upper,    format = "f", digits = 0, big.mark = ","), "\n"))
cat(paste("Probability of Loss:   ", round(prob_of_loss, 2), "%\n"))
cat("--------------------------------------------------\n")
cat("           BREAK-EVEN TIMELINE PROBABILITIES      \n")
cat("--------------------------------------------------\n")

for (yr in names(be_probs)) {
  if (is.na(yr) || yr == "NA") {
    cat(paste("Never breaks even (loss scenario):", be_probs[yr], "%\n"))
  } else {
    cat(paste("Breaks even in Year", yr, ":", be_probs[yr], "%\n"))
  }
}
cat("==================================================\n")

plot_data <- data.frame(eNPV = psa_enpv_results)

ggplot(plot_data, aes(x = eNPV)) +
  geom_histogram(aes(y = after_stat(density)),
                 bins = 60, fill = "lightblue", color = "grey40", alpha = 0.7) +
