library(readxl)      
library(dplyr)       
library(data.tree)
library(ggplot2)
library(scales)
library(mc2d)

file_name <- "MelatoninSCNL.xlsx"

revenue_data <- read_excel(file_name, sheet = "Revenue")
costs_data <- read_excel(file_name, sheet = "Costs")
assumptions_data <- read_excel(file_name, sheet = "Assumptions")

price_per_pack <- assumptions_data %>% filter(Parameters == "Price_Per_pack(1mg)30st") %>% pull(Baseline)
discount_rate <- assumptions_data %>% filter(Parameters == "Discount_Rate") %>% pull(Baseline)
study_costs <- assumptions_data %>% filter(Parameters == "Study_Costs") %>% pull(Baseline)

prob_study_on_time <- assumptions_data %>% filter(Parameters == "Prob_Study_On_Time") %>% pull(Baseline)
prob_ema_approved  <- assumptions_data %>% filter(Parameters == "Prob_EMA_Approved") %>% pull(Baseline)

prob_access_scan <- assumptions_data %>% filter(Parameters == "Scandinavian_prob_client_aquisition") %>% pull(Baseline)
prob_access_uk   <- assumptions_data %>% filter(Parameters == "UK_annual_prob_client_aquisition") %>% pull(Baseline)
prob_access_nl   <- assumptions_data %>% filter(Parameters == "NL_annual_prob_client_aquisition") %>% pull(Baseline)
prob_access_de   <- assumptions_data %>% filter(Parameters == "DE_annual_prob_client_aquisition") %>% pull(Baseline)

combined_data <- left_join(revenue_data, costs_data, by = c("Country", "Year"))

cash_flow_data <- combined_data %>%
  mutate(
    Gross_Revenue = `Pack of 30` * Market_Share_Pct * price_per_pack,
    Total_COGS = `Pack of 30` * Market_Share_Pct * COGS_Per_pack30,
    Operating_Cash_Flow = Gross_Revenue - Total_COGS,
    Discounted_CF = Operating_Cash_Flow / ((1 + discount_rate) ^ Year)
  )

npv_by_country <- cash_flow_data %>%
  group_by(Country) %>%
  summarise(Country_NPV = sum(Discounted_CF)) %>%
  mutate(
    Prob_Acquisition = case_when(
      Country == "Scandinavian" ~ prob_access_scan,
      Country == "UK"           ~ prob_access_uk,
      Country == "NL"           ~ prob_access_nl,
      Country == "DE"           ~ prob_access_de
    ),
    Risk_Adjusted_NPV = Country_NPV * Prob_Acquisition
  )

print("--- VERIFICATION: MARKET LEVEL RISK ADJUSTMENT ---")
print(npv_by_country)

payoff_on_time <- sum(npv_by_country$Risk_Adjusted_NPV) - (study_costs / ((1 + discount_rate) ^ 1))

payoff_delayed <- cash_flow_data %>%
  mutate(
    Delayed_Op_CF = if_else(Year == 1, 0, Operating_Cash_Flow),
    Delayed_Disc_CF = Delayed_Op_CF / ((1 + discount_rate) ^ Year)
  ) %>%
  group_by(Country) %>%
  summarise(Delayed_Country_NPV = sum(Delayed_Disc_CF)) %>%
  left_join(npv_by_country %>% select(Country, Prob_Acquisition), by = "Country") %>%
  mutate(Delayed_Risk_Adj_NPV = Delayed_Country_NPV * Prob_Acquisition) %>%
  summarise(Total = sum(Delayed_Risk_Adj_NPV)) %>%
  pull(Total) - (study_costs / ((1 + discount_rate) ^ 1))

mellozzan_tree <- Node$new("Mellozzan Project")
on_time_node <- mellozzan_tree$AddChild("Study: On Time")
on_time_node$probability <- prob_study_on_time
delayed_node <- mellozzan_tree$AddChild("Study: Delayed")
delayed_node$probability <- 1 - prob_study_on_time

app_on_time <- on_time_node$AddChild("EMA Approved (Fast)")
app_on_time$probability <- prob_ema_approved
app_on_time$payoff <- payoff_on_time
rej_on_time <- on_time_node$AddChild("EMA Rejected (Fast)")
rej_on_time$probability <- 1 - prob_ema_approved
rej_on_time$payoff <- 0

app_delayed <- delayed_node$AddChild("EMA Approved (Slow)")
app_delayed$probability <- prob_ema_approved
app_delayed$payoff <- payoff_delayed
rej_delayed <- delayed_node$AddChild("EMA Rejected (Slow)")
rej_delayed$probability <- 1 - prob_ema_approved
rej_delayed$payoff <- 0

calculate_ev <- function(node) {
  if (node$isLeaf) {
    node$expected_value <- node$payoff
  } else {
    node$expected_value <- sum(sapply(node$children, function(child) {
      child$probability * calculate_ev(child)
    }))
  }
  return(node$expected_value)
}

project_enpv <- calculate_ev(mellozzan_tree)

print(mellozzan_tree, "probability", "payoff", "expected_value")
print(paste("Final Project eNPV (Risk-Adjusted):", round(project_enpv, 2)))

# --- PHASE 4, STEP 7: BASELINE BREAK-EVEN ANALYSIS ---

# 1. Sum up the cash flows across all countries for each year
yearly_breakdown <- cash_flow_data %>%
  group_by(Year) %>%
  summarise(
    Yearly_Operating_CF = sum(Operating_Cash_Flow),
    Yearly_Discounted_CF = sum(Discounted_CF)
  )

# 2. Subtract the Study Cost from Year 1 and calculate Cumulative NPV
yearly_breakdown <- yearly_breakdown %>%
  mutate(
    Net_Yearly_NPV = if_else(Year == 1, 
                             Yearly_Discounted_CF - (study_costs / ((1 + discount_rate) ^ 1)), 
                             Yearly_Discounted_CF),
    Cumulative_NPV = cumsum(Net_Yearly_NPV)
  )

# 3. Identify the exact Break-Even Year
# It finds the first year where Cumulative_NPV is greater than 0
break_even_year <- yearly_breakdown %>%
  filter(Cumulative_NPV > 0) %>%
  slice(1) %>%
  pull(Year)

# 4. Print the results
print("--- BASELINE CUMULATIVE NPV & BREAK-EVEN ---")
print(yearly_breakdown %>% select(Year, Net_Yearly_NPV, Cumulative_NPV))

if(length(break_even_year) > 0) {
  print(paste("Baseline Break-Even achieved in Year:", break_even_year))
} else {
  print("Baseline Break-Even is NOT achieved within 5 years.")
}


# --- UPGRADE: STEP 2 - DYNAMIC ENGINE WITH BREAK-EVEN & DSA LOOP ---

# 1. The Upgraded Engine
run_mellozzan_model <- function(current_assumptions) {
  
  get_val <- function(p_name) { current_assumptions %>% filter(Parameters == p_name) %>% pull(Baseline) }
  get_base <- function(p_name) { assumptions_data %>% filter(Parameters == p_name) %>% pull(Baseline) }
  
  price_per_pack     <- get_val("Price_Per_pack(1mg)30st")
  discount_rate      <- get_val("Discount_Rate") 
  study_costs        <- get_val("Study_Costs")
  prob_study_on_time <- get_val("Prob_Study_On_Time")
  prob_ema_approved  <- get_val("Prob_EMA_Approved")
  
  prob_access_scan   <- get_val("Scandinavian_prob_client_aquisition")
  prob_access_uk     <- get_val("UK_annual_prob_client_aquisition")
  prob_access_nl     <- get_val("NL_annual_prob_client_aquisition")
  prob_access_de     <- get_val("DE_annual_prob_client_aquisition")
  
  scale_vol_scan <- get_val("Scandinavian_annual_tablets") / get_base("Scandinavian_annual_tablets")
  scale_vol_uk   <- get_val("UK_annual_tablets") / get_base("UK_annual_tablets")
  scale_vol_nl   <- get_val("NL_annual_tablets") / get_base("NL_annual_tablets")
  scale_vol_de   <- get_val("DE_annual_tablets") / get_base("DE_annual_tablets")
  
  scale_shr_scan <- get_val("Scandinavian_Peak_Market_Share") / get_base("Scandinavian_Peak_Market_Share")
  scale_shr_uk   <- get_val("UK_annual_Peak_Market_Share") / get_base("UK_annual_Peak_Market_Share")
  scale_shr_nl   <- get_val("NL_annual_Peak_Market_Share") / get_base("NL_annual_Peak_Market_Share")
  scale_shr_de   <- get_val("DE_annual_Peak_Market_Share") / get_base("DE_annual_Peak_Market_Share")
  
  scale_cogs <- get_val("COGS_Per_pack30_year1") / get_base("COGS_Per_pack30_year1")
  
  temp_cash_flow <- combined_data %>%
    mutate(
      `Pack of 30` = case_when(
        Country == "Scandinavian" ~ `Pack of 30` * scale_vol_scan,
        Country == "UK"           ~ `Pack of 30` * scale_vol_uk,
        Country == "NL"           ~ `Pack of 30` * scale_vol_nl,
        Country == "DE"           ~ `Pack of 30` * scale_vol_de
      ),
      Market_Share_Pct = case_when(
        Country == "Scandinavian" ~ Market_Share_Pct * scale_shr_scan,
        Country == "UK"           ~ Market_Share_Pct * scale_shr_uk,
        Country == "NL"           ~ Market_Share_Pct * scale_shr_nl,
        Country == "DE"           ~ Market_Share_Pct * scale_shr_de
      ),
      COGS_Per_pack30 = COGS_Per_pack30 * scale_cogs,
      
      Gross_Revenue = `Pack of 30` * Market_Share_Pct * price_per_pack,
      Total_COGS = `Pack of 30` * Market_Share_Pct * COGS_Per_pack30,
      Operating_Cash_Flow = Gross_Revenue - Total_COGS,
      Discounted_CF = Operating_Cash_Flow / ((1 + discount_rate) ^ Year)
    )
  
  temp_npv_by_country <- temp_cash_flow %>%
    group_by(Country) %>%
    summarise(Country_NPV = sum(Discounted_CF)) %>%
    mutate(
      Prob_Acquisition = case_when(
        Country == "Scandinavian" ~ prob_access_scan,
        Country == "UK"           ~ prob_access_uk,
        Country == "NL"           ~ prob_access_nl,
        Country == "DE"           ~ prob_access_de
      ),
      Risk_Adjusted_NPV = Country_NPV * Prob_Acquisition
    )
  
  payoff_on_time <- sum(temp_npv_by_country$Risk_Adjusted_NPV) - (study_costs / ((1 + discount_rate) ^ 1))
  
  payoff_delayed <- temp_cash_flow %>%
    mutate(
      Delayed_Op_CF = if_else(Year == 1, 0, Operating_Cash_Flow),
      Delayed_Disc_CF = Delayed_Op_CF / ((1 + discount_rate) ^ Year)
    ) %>%
    group_by(Country) %>%
    summarise(Delayed_Country_NPV = sum(Delayed_Disc_CF)) %>%
    left_join(temp_npv_by_country %>% select(Country, Prob_Acquisition), by = "Country") %>%
    mutate(Delayed_Risk_Adj_NPV = Delayed_Country_NPV * Prob_Acquisition) %>%
    summarise(Total = sum(Delayed_Risk_Adj_NPV)) %>%
    pull(Total) - (study_costs / ((1 + discount_rate) ^ 1))
  
  temp_tree <- Node$new("Temp")
  on_time_node <- temp_tree$AddChild("OnTime", probability = prob_study_on_time)
  delayed_node <- temp_tree$AddChild("Delayed", probability = 1 - prob_study_on_time)
  
  app_on_time <- on_time_node$AddChild("AppFast", probability = prob_ema_approved, payoff = payoff_on_time)
  rej_on_time <- on_time_node$AddChild("RejFast", probability = 1 - prob_ema_approved, payoff = 0)
  
  app_delayed <- delayed_node$AddChild("AppSlow", probability = prob_ema_approved, payoff = payoff_delayed)
  rej_delayed <- delayed_node$AddChild("RejSlow", probability = 1 - prob_ema_approved, payoff = 0)
  
  calc_ev <- function(node) {
    if (node$isLeaf) { return(node$payoff) } 
    else { return(sum(sapply(node$children, function(child) { child$probability * calc_ev(child) }))) }
  }
  
  final_enpv <- calc_ev(temp_tree)
  
  # --- THE NEW BREAK-EVEN MATH ---
  temp_yearly <- temp_cash_flow %>%
    group_by(Year) %>%
    summarise(Yearly_Discounted_CF = sum(Discounted_CF)) %>%
    mutate(
      Net_Yearly_NPV = if_else(Year == 1, 
                               Yearly_Discounted_CF - (study_costs / ((1 + discount_rate) ^ 1)), 
                               Yearly_Discounted_CF),
      Cumulative_NPV = cumsum(Net_Yearly_NPV)
    )
  
  # Find the first year it turns positive. If it never does, assign NA.
  be_year <- temp_yearly %>% filter(Cumulative_NPV > 0) %>% slice(1) %>% pull(Year)
  if(length(be_year) == 0) { be_year <- NA }
  
  # The engine now returns BOTH values as a list!
  return(list(
    eNPV = final_enpv,
    BreakEven = be_year
  ))
}


# 2. RUN THE UPGRADED DSA LOOP

dsa_params <- assumptions_data %>% filter(Min != Max)

# We expanded the table to hold the new Break-Even results
dsa_results <- data.frame(
  Parameter = character(), Min_Value = numeric(), Max_Value = numeric(),
  eNPV_at_Min = numeric(), eNPV_at_Max = numeric(), 
  BreakEven_at_Min = numeric(), BreakEven_at_Max = numeric(), # NEW COLUMNS
  stringsAsFactors = FALSE
)

for (i in 1:nrow(dsa_params)) {
  param_name <- dsa_params$Parameters[i]
  
  # Run MIN
  temp_min <- assumptions_data
  temp_min$Baseline[temp_min$Parameters == param_name] <- dsa_params$Min[i]
  res_min <- run_mellozzan_model(temp_min) # res_min now holds $eNPV and $BreakEven
  
  # Run MAX
  temp_max <- assumptions_data
  temp_max$Baseline[temp_max$Parameters == param_name] <- dsa_params$Max[i]
  res_max <- run_mellozzan_model(temp_max) # res_max now holds $eNPV and $BreakEven
  
  # Save the results
  dsa_results <- rbind(dsa_results, data.frame(
    Parameter = param_name,
    Min_Value = dsa_params$Min[i],
    Max_Value = dsa_params$Max[i],
    eNPV_at_Min = res_min$eNPV,
    eNPV_at_Max = res_max$eNPV,
    BreakEven_at_Min = res_min$BreakEven,
    BreakEven_at_Max = res_max$BreakEven
  ))
}

dsa_results <- dsa_results %>%
  mutate(Swing = abs(eNPV_at_Max - eNPV_at_Min)) %>%
  arrange(desc(Swing))

print("--- DSA SWING RESULTS (WITH BREAK-EVEN) ---")
print(dsa_results %>% select(Parameter, eNPV_at_Min, eNPV_at_Max, BreakEven_at_Min, BreakEven_at_Max))

