# --- PHASE 6, STEP 1: SETUP RANDOM NUMBER GENERATION (PERT) ---

library(mc2d)

# 1. Define how many alternate realities we want to simulate
n_sims <- 10000

# 2. Grab the variables that actually fluctuate (Min != Max)
psa_params <- assumptions_data %>% filter(Min != Max)

# 3. Create a massive table to hold our 10,000 different scenarios
simulated_inputs <- data.frame(Simulation_ID = 1:n_sims)

# 4. Generate 10,000 random numbers for EVERY parameter using the PERT distribution
for (i in 1:nrow(psa_params)) {
  param_name <- psa_params$Parameters[i]
  min_val    <- psa_params$Min[i]
  base_val   <- psa_params$Baseline[i]
  max_val    <- psa_params$Max[i]
  
  # rpert generates random numbers weighted heavily toward the baseline (mode)
  simulated_inputs[[param_name]] <- rpert(n_sims, min = min_val, mode = base_val, max = max_val)
}

print("--- STEP 1 COMPLETE: 10,000 Scenarios Generated Successfully ---")

# --- UPGRADE: STEP 3 - MONTE CARLO LOOP WITH BREAK-EVEN ---

# 1. Create empty vectors to store BOTH results for all 10,000 runs
psa_enpv_results <- numeric(n_sims)
psa_breakeven_results <- numeric(n_sims) # NEW: Stores the break-even year

print("Starting Simulation Engine (with Break-Even Tracking)... This takes 30-60 seconds.")

# 2. Feed all 10,000 scenarios through the Upgraded Engine
for (sim in 1:n_sims) {
  
  if (sim %% 1000 == 0) {
    print(paste("Running simulation", sim, "of", n_sims, "..."))
  }
  
  current_sim_assumptions <- assumptions_data
  
  for (i in 1:nrow(psa_params)) {
    param_name <- psa_params$Parameters[i]
    current_sim_assumptions$Baseline[current_sim_assumptions$Parameters == param_name] <- simulated_inputs[[param_name]][sim]
  }
  
  # Run the engine and extract BOTH outputs!
  sim_results <- run_mellozzan_model(current_sim_assumptions)
  
  psa_enpv_results[sim] <- sim_results$eNPV
  psa_breakeven_results[sim] <- sim_results$BreakEven
}

print("--- STEP 3 COMPLETE: Monte Carlo Simulation Finished! ---")


# --- UPGRADE: STEP 4 - CALCULATE NEW STATISTICS & EXECUTIVE SUMMARY ---

# Core financial stats
mean_enpv <- mean(psa_enpv_results)
median_enpv <- median(psa_enpv_results)
ci_lower <- quantile(psa_enpv_results, 0.025)
ci_upper <- quantile(psa_enpv_results, 0.975)
prob_of_loss <- sum(psa_enpv_results < 0) / n_sims * 100

# NEW: Calculate Break-Even Probabilities
# We count how many times each year (or NA/Never) appears in our 10,000 runs
be_counts <- table(psa_breakeven_results, useNA = "always")
be_probs <- round((be_counts / n_sims) * 100, 1)

# Print the final Executive Summary
print("==================================================")
print("     MONTE CARLO SIMULATION: EXECUTIVE SUMMARY    ")
print("==================================================")
print(paste("Mean Expected NPV:      €", formatC(mean_enpv, format="f", digits=0, big.mark=",")))
print(paste("Median Expected NPV:    €", formatC(median_enpv, format="f", digits=0, big.mark=",")))
print(paste("Worst Case (95% CI):    €", formatC(ci_lower, format="f", digits=0, big.mark=",")))
print(paste("Best Case (95% CI):     €", formatC(ci_upper, format="f", digits=0, big.mark=",")))
print(paste("Probability of Loss:   ", round(prob_of_loss, 2), "%"))
print("--------------------------------------------------")
print("           BREAK-EVEN TIMELINE RISKS              ")
print("--------------------------------------------------")

# Dynamically print the probability of breaking even in each year
for (yr in names(be_probs)) {
  if (is.na(yr)) {
    print(paste("Never breaks even (Loss): ", be_probs[yr], "%"))
  } else {
    print(paste("Breaks even in Year", yr, ":   ", be_probs[yr], "%"))
  }
}
print("==================================================")

