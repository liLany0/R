library(readxl)
library(dplyr)
library(tidyr)
library(data.tree)
library(ggplot2)
library(scales)
library(mc2d)


file_name <- "Melatonin.xlsx"

revenue_data     <- read_excel(file_name, sheet = "Revenue")
costs_data       <- read_excel(file_name, sheet = "Costs")
assumptions_data <- read_excel(file_name, sheet = "Assumptions")

# Helper: pull a single baseline value cleanly
get_assumption <- function(df, p_name) {
  df %>% filter(trimws(Parameters) == p_name) %>% pull(Baseline)
}

# --- Pull baseline scalars ---
price_per_pack     <- get_assumption(assumptions_data, "Price_Per_pack(1mg)30st")
discount_rate      <- get_assumption(assumptions_data, "Discount_Rate")
study_costs        <- get_assumption(assumptions_data, "Study_Costs")
prob_study_on_time <- get_assumption(assumptions_data, "Prob_Study_On_Time")
prob_ema_approved  <- get_assumption(assumptions_data, "Prob_EMA_Approved")
prob_access_scan   <- get_assumption(assumptions_data, "Scandinavian_prob_client_aquisition")
prob_access_uk     <- get_assumption(assumptions_data, "UK_annual_prob_client_aquisition")
prob_access_nl     <- get_assumption(assumptions_data, "NL_annual_prob_client_aquisition")
prob_access_de     <- get_assumption(assumptions_data, "DE_annual_prob_client_aquisition")
# Hidden Costs: % of Gross Revenue lost to unplanned costs (distribution,
# chargebacks, write-offs, etc.). Applied as a revenue haircut.
hidden_costs_pct   <- get_assumption(assumptions_data, "Hidden Costs")


# The Costs sheet has two types of rows:
#   (a) COGS rows  — Des. == "COGS_Per_pack30", one per country per year
#   (b) Fee rows   — Des. == a fee name (e.g. "MRP fee NL"), one-off or annual
#   (c) Study cost — Country == "NL", Des. == "Study_Costs " → EXCLUDED here
#                    (handled via Assumptions tab to avoid double-counting)
#
# Strategy:
#   1. Exclude the Study_Costs row (tagged as NL in this data version).
#   2. Map DK/FL/NO/SE sub-countries → "Scandinavian" umbrella and SUM costs.
#   3. Separate COGS rows from fee rows.
#   4. Pivot fee rows wide so each fee gets its own column.
#   5. Join COGS and fees back together, then join to revenue.

# Step 1 & 2: Exclude Study_Costs and remap Scandinavian sub-countries
costs_remapped <- costs_data %>%
  filter(trimws(Des.) != "Study_Costs") %>%          # remove study cost row
  mutate(
    Country = case_when(
      Country %in% c("DK", "FL", "NO", "SE", "Scandinavian") ~ "Scandinavian",
      TRUE ~ Country
    )
  )

# Step 3a: Extract COGS rows (one value per Country × Year after summing subs)
cogs_clean <- costs_remapped %>%
  filter(Des. == "COGS_Per_pack30") %>%
  group_by(Country, Year) %>%
  summarise(COGS_Per_pack30 = sum(Cost_Value, na.rm = TRUE), .groups = "drop")

# Step 3b: Extract fee rows, group (sum Scandinavian sub-countries), pivot wide
fees_clean <- costs_remapped %>%
  filter(Des. != "COGS_Per_pack30") %>%
  group_by(Country, Year, Des.) %>%
  summarise(Cost_Value = sum(Cost_Value, na.rm = TRUE), .groups = "drop") %>%
  pivot_wider(
    names_from  = Des.,
    values_from = Cost_Value,
    values_fill = list(Cost_Value = 0)
  )

# Step 4: Merge COGS and fees into one costs table
costs_clean <- full_join(cogs_clean, fees_clean, by = c("Country", "Year"))


combined_data <- left_join(revenue_data, costs_clean, by = c("Country", "Year"))

# All possible fee column names (any_of handles missing ones gracefully)
fee_columns <- c(
  "NL Initital Registration", "NL annaul fee", "MRP fee NL",
  "MRP fee DE", "MRP fee DK", "MRP fee FL", "MRP fee NO", "MRP fee SE",
  "UK registration",
  "MRP fee NL annually", "MRP fee DE annually", "MRP fee DK annually",
  "MRP fee FL annually", "MRP fee NO annually", "MRP fee SE annually",
  "UK registration annually"
)

cash_flow_data <- combined_data %>%
  rowwise() %>%
  mutate(
    Total_Fixed_Costs = sum(c_across(any_of(fee_columns)), na.rm = TRUE)
  ) %>%
  ungroup() %>%
  mutate(
    Gross_Revenue        = Total_Market_Pack * Market_Share_Pct * price_per_pack,
    Hidden_Costs         = Gross_Revenue * hidden_costs_pct,
    Total_COGS           = Total_Market_Pack * Market_Share_Pct * COGS_Per_pack30,
    Operating_Cash_Flow  = Gross_Revenue - Hidden_Costs - Total_COGS - Total_Fixed_Costs,
    Discounted_CF        = Operating_Cash_Flow / ((1 + discount_rate) ^ Year)
  )


npv_by_country <- cash_flow_data %>%
  group_by(Country) %>%
  summarise(Country_NPV = sum(Discounted_CF), .groups = "drop") %>%
  mutate(
    Prob_Acquisition = case_when(
      Country == "Scandinavian" ~ prob_access_scan,
      Country == "UK"           ~ prob_access_uk,
      Country == "NL"           ~ prob_access_nl,
      Country == "DE"           ~ prob_access_de
    ),
    Risk_Adjusted_NPV = Country_NPV * Prob_Acquisition
  )

cat("\n--- VERIFICATION: MARKET LEVEL RISK ADJUSTMENT ---\n")
print(npv_by_country)

# Decision tree payoffs
# On-time: full 5-year cash flows, minus PV of study cost
payoff_on_time <- sum(npv_by_country$Risk_Adjusted_NPV) -
  (study_costs / ((1 + discount_rate) ^ 1))

# Delayed: Year 1 cash flow dropped (= 0), otherwise same
payoff_delayed <- cash_flow_data %>%
  mutate(
    Delayed_Op_CF  = if_else(Year == 1, 0, Operating_Cash_Flow),
    Delayed_Disc_CF = Delayed_Op_CF / ((1 + discount_rate) ^ Year)
  ) %>%
  group_by(Country) %>%
  summarise(Delayed_Country_NPV = sum(Delayed_Disc_CF), .groups = "drop") %>%
  left_join(npv_by_country %>% select(Country, Prob_Acquisition), by = "Country") %>%
  mutate(Delayed_Risk_Adj_NPV = Delayed_Country_NPV * Prob_Acquisition) %>%
  summarise(Total = sum(Delayed_Risk_Adj_NPV)) %>%
  pull(Total) - (study_costs / ((1 + discount_rate) ^ 1))

# Build decision tree
mellozzan_tree <- Node$new("Mellozzan Project")

on_time_node <- mellozzan_tree$AddChild("Study: On Time")
on_time_node$probability <- prob_study_on_time

app_on_time <- on_time_node$AddChild("EMA Approved (Fast)")
app_on_time$probability <- prob_ema_approved
app_on_time$payoff      <- payoff_on_time

rej_on_time <- on_time_node$AddChild("EMA Rejected (Fast)")
rej_on_time$probability <- 1 - prob_ema_approved
rej_on_time$payoff      <- 0

delayed_node <- mellozzan_tree$AddChild("Study: Delayed")
delayed_node$probability <- 1 - prob_study_on_time

app_delayed <- delayed_node$AddChild("EMA Approved (Slow)")
app_delayed$probability <- prob_ema_approved
app_delayed$payoff      <- payoff_delayed

rej_delayed <- delayed_node$AddChild("EMA Rejected (Slow)")
rej_delayed$probability <- 1 - prob_ema_approved
rej_delayed$payoff      <- 0

# Roll back expected values
calculate_ev <- function(node) {
  if (node$isLeaf) {
    node$expected_value <- node$payoff
  } else {
    node$expected_value <- sum(sapply(node$children, function(child) {
      child$probability * calculate_ev(child)
    }))
  }
  return(node$expected_value)
}

project_enpv <- calculate_ev(mellozzan_tree)

cat("\n--- DECISION TREE ---\n")
print(mellozzan_tree, "probability", "payoff", "expected_value")
cat(paste("Final Project eNPV (Risk-Adjusted): €",
          formatC(project_enpv, format = "f", digits = 2, big.mark = ","), "\n"))


yearly_breakdown <- cash_flow_data %>%
  group_by(Year) %>%
  summarise(
    Yearly_Operating_CF  = sum(Operating_Cash_Flow),
    Yearly_Discounted_CF = sum(Discounted_CF),
    .groups = "drop"
  ) %>%
  mutate(
    # Study cost is a Year-1 outlay; subtract its PV only in Year 1
    Net_Yearly_NPV = if_else(
      Year == 1,
      Yearly_Discounted_CF - (study_costs / ((1 + discount_rate) ^ 1)),
      Yearly_Discounted_CF
    ),
    Cumulative_NPV = cumsum(Net_Yearly_NPV)
  )

break_even_year <- yearly_breakdown %>%
  filter(Cumulative_NPV > 0) %>%
  slice(1) %>%
  pull(Year)

cat("\n--- BASELINE CUMULATIVE NPV & BREAK-EVEN ---\n")
print(yearly_breakdown %>% select(Year, Net_Yearly_NPV, Cumulative_NPV))

if (length(break_even_year) > 0) {
  cat(paste("Baseline Break-Even achieved in Year:", break_even_year, "\n"))
} else {
  cat("Baseline Break-Even is NOT achieved within the forecast horizon.\n")
}

# IMPORTANT DESIGN NOTE:
#   combined_data is used as the base inside run_mellozzan_model.
#   It is constructed ONCE from the baseline data and reused.
#   Volume and market share are SCALED relative to their baseline values,
#   so we never need to re-join raw sheets inside the loop — only scalars change.

run_mellozzan_model <- function(current_assumptions) {
  
  gv <- function(p) current_assumptions %>% filter(trimws(Parameters) == p) %>% pull(Baseline)
  gb <- function(p) assumptions_data    %>% filter(trimws(Parameters) == p) %>% pull(Baseline)
  
  # Scalars from current scenario
  price_per_pack     <- gv("Price_Per_pack(1mg)30st")
  discount_rate      <- gv("Discount_Rate")
  study_costs        <- gv("Study_Costs")
  prob_study_on_time <- gv("Prob_Study_On_Time")
  prob_ema_approved  <- gv("Prob_EMA_Approved")
  prob_access_scan   <- gv("Scandinavian_prob_client_aquisition")
  prob_access_uk     <- gv("UK_annual_prob_client_aquisition")
  prob_access_nl     <- gv("NL_annual_prob_client_aquisition")
  prob_access_de     <- gv("DE_annual_prob_client_aquisition")
  hidden_costs_pct   <- gv("Hidden Costs")
  
  # Volume scaling factors (ratio of scenario value to baseline value)
  scale_vol_scan <- gv("Scandinavian_annual_tablets") / gb("Scandinavian_annual_tablets")
  scale_vol_uk   <- gv("UK_annual_tablets")           / gb("UK_annual_tablets")
  scale_vol_nl   <- gv("NL_annual_tablets")           / gb("NL_annual_tablets")
  scale_vol_de   <- gv("DE_annual_tablets")           / gb("DE_annual_tablets")
  
  # Market share scaling factors
  scale_shr_scan <- gv("Scandinavian_Peak_Market_Share") / gb("Scandinavian_Peak_Market_Share")
  scale_shr_uk   <- gv("UK_annual_Peak_Market_Share")    / gb("UK_annual_Peak_Market_Share")
  scale_shr_nl   <- gv("NL_annual_Peak_Market_Share")    / gb("NL_annual_Peak_Market_Share")
  scale_shr_de   <- gv("DE_annual_Peak_Market_Share")    / gb("DE_annual_Peak_Market_Share")
  
  # COGS scaling factor (Year 1 COGS drives the scalar; all years scale proportionally)
  scale_cogs <- gv("COGS_Per_pack30_year1") / gb("COGS_Per_pack30_year1")
  
  # Apply scaling to combined_data (which already has COGS_Per_pack30 correctly named)
  temp_cash_flow <- combined_data %>%
    mutate(
      Total_Market_Pack = case_when(
        Country == "Scandinavian" ~ Total_Market_Pack * scale_vol_scan,
        Country == "UK"           ~ Total_Market_Pack * scale_vol_uk,
        Country == "NL"           ~ Total_Market_Pack * scale_vol_nl,
        Country == "DE"           ~ Total_Market_Pack * scale_vol_de
      ),
      Market_Share_Pct = case_when(
        Country == "Scandinavian" ~ Market_Share_Pct * scale_shr_scan,
        Country == "UK"           ~ Market_Share_Pct * scale_shr_uk,
        Country == "NL"           ~ Market_Share_Pct * scale_shr_nl,
        Country == "DE"           ~ Market_Share_Pct * scale_shr_de
      ),
      # Scale COGS — applied to the already year-varying COGS column
      COGS_Per_pack30 = COGS_Per_pack30 * scale_cogs
    ) %>%
    rowwise() %>%
    mutate(
      Total_Fixed_Costs = sum(c_across(any_of(fee_columns)), na.rm = TRUE)
    ) %>%
    ungroup() %>%
    mutate(
      Gross_Revenue       = Total_Market_Pack * Market_Share_Pct * price_per_pack,
      Hidden_Costs        = Gross_Revenue * hidden_costs_pct,
      Total_COGS          = Total_Market_Pack * Market_Share_Pct * COGS_Per_pack30,
      Operating_Cash_Flow = Gross_Revenue - Hidden_Costs - Total_COGS - Total_Fixed_Costs,
      Discounted_CF       = Operating_Cash_Flow / ((1 + discount_rate) ^ Year)
    )
  
  temp_npv_by_country <- temp_cash_flow %>%
    group_by(Country) %>%
    summarise(Country_NPV = sum(Discounted_CF), .groups = "drop") %>%
    mutate(
      Prob_Acquisition = case_when(
        Country == "Scandinavian" ~ prob_access_scan,
        Country == "UK"           ~ prob_access_uk,
        Country == "NL"           ~ prob_access_nl,
        Country == "DE"           ~ prob_access_de
      ),
      Risk_Adjusted_NPV = Country_NPV * Prob_Acquisition
    )
  
  payoff_on_time <- sum(temp_npv_by_country$Risk_Adjusted_NPV) -
    (study_costs / ((1 + discount_rate) ^ 1))
  
  payoff_delayed <- temp_cash_flow %>%
    mutate(
      Delayed_Op_CF   = if_else(Year == 1, 0, Operating_Cash_Flow),
      Delayed_Disc_CF = Delayed_Op_CF / ((1 + discount_rate) ^ Year)
    ) %>%
    group_by(Country) %>%
    summarise(Delayed_Country_NPV = sum(Delayed_Disc_CF), .groups = "drop") %>%
    left_join(temp_npv_by_country %>% select(Country, Prob_Acquisition), by = "Country") %>%
    mutate(Delayed_Risk_Adj_NPV = Delayed_Country_NPV * Prob_Acquisition) %>%
    summarise(Total = sum(Delayed_Risk_Adj_NPV)) %>%
    pull(Total) - (study_costs / ((1 + discount_rate) ^ 1))
  
  # Decision tree rollback
  temp_tree    <- Node$new("Temp")
  on_t         <- temp_tree$AddChild("OnTime",  probability = prob_study_on_time)
  del_t        <- temp_tree$AddChild("Delayed", probability = 1 - prob_study_on_time)
  on_t$AddChild("AppFast", probability = prob_ema_approved,     payoff = payoff_on_time)
  on_t$AddChild("RejFast", probability = 1 - prob_ema_approved, payoff = 0)
  del_t$AddChild("AppSlow", probability = prob_ema_approved,     payoff = payoff_delayed)
  del_t$AddChild("RejSlow", probability = 1 - prob_ema_approved, payoff = 0)
  
  calc_ev <- function(node) {
    if (node$isLeaf) return(node$payoff)
    sum(sapply(node$children, function(child) child$probability * calc_ev(child)))
  }
  
  final_enpv <- calc_ev(temp_tree)
  
  # Break-even: first year cumulative NPV goes positive (and stays positive
  # through end of horizon — handles edge case of re-crossing zero)
  temp_yearly <- temp_cash_flow %>%
    group_by(Year) %>%
    summarise(Yearly_Discounted_CF = sum(Discounted_CF), .groups = "drop") %>%
    mutate(
      Net_Yearly_NPV = if_else(
        Year == 1,
        Yearly_Discounted_CF - (study_costs / ((1 + discount_rate) ^ 1)),
        Yearly_Discounted_CF
      ),
      Cumulative_NPV = cumsum(Net_Yearly_NPV)
    )
  
  # Only count break-even if cumulative NPV stays positive from that year onward
  max_year <- max(temp_yearly$Year)
  be_year  <- NA
  
  for (yr in temp_yearly$Year) {
    cum_from_here <- temp_yearly %>% filter(Year >= yr) %>% pull(Cumulative_NPV)
    if (all(cum_from_here > 0)) {
      be_year <- yr
      break
    }
  }
  
  return(list(eNPV = final_enpv, BreakEven = be_year))
}


dsa_params <- assumptions_data %>% filter(Min != Max)

dsa_results <- data.frame(
  Parameter        = character(),
  Min_Value        = numeric(),
  Max_Value        = numeric(),
  eNPV_at_Min      = numeric(),
  eNPV_at_Max      = numeric(),
  BreakEven_at_Min = numeric(),
  BreakEven_at_Max = numeric(),
  stringsAsFactors = FALSE
)

for (i in seq_len(nrow(dsa_params))) {
  param_name <- dsa_params$Parameters[i]
  
  temp_min <- assumptions_data
  temp_min$Baseline[temp_min$Parameters == param_name] <- dsa_params$Min[i]
  res_min  <- run_mellozzan_model(temp_min)
  
  temp_max <- assumptions_data
  temp_max$Baseline[temp_max$Parameters == param_name] <- dsa_params$Max[i]
  res_max  <- run_mellozzan_model(temp_max)
  
  dsa_results <- rbind(dsa_results, data.frame(
    Parameter        = param_name,
    Min_Value        = dsa_params$Min[i],
    Max_Value        = dsa_params$Max[i],
    eNPV_at_Min      = res_min$eNPV,
    eNPV_at_Max      = res_max$eNPV,
    BreakEven_at_Min = ifelse(is.na(res_min$BreakEven), NA_real_, res_min$BreakEven),
    BreakEven_at_Max = ifelse(is.na(res_max$BreakEven), NA_real_, res_max$BreakEven)
  ))
}

dsa_results <- dsa_results %>%
  mutate(Swing = abs(eNPV_at_Max - eNPV_at_Min)) %>%
  arrange(desc(Swing))

cat("\n--- DSA SWING RESULTS (WITH BREAK-EVEN) ---\n")
print(dsa_results %>% select(Parameter, eNPV_at_Min, eNPV_at_Max,
                             BreakEven_at_Min, BreakEven_at_Max, Swing))

# Tornado chart
tornado_data <- dsa_results %>%
  arrange(Swing) %>%
  mutate(Parameter = factor(Parameter, levels = Parameter))

ggplot(tornado_data) +
